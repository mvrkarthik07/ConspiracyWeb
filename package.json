{
  "name": "conspiracy-web-sg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "next dev -p 3000",
    "dev:frontend": "npm run dev --prefix frontend -- --port 5173",
    "dev:all": "concurrently -n api,web -c \"white,white\" \"npm run dev:api\" \"npm run dev:frontend\"",
    "build": "next build",
